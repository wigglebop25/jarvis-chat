# Copy this file to .env and fill in your values

# LLM
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
LLM_PROVIDER=gemini
LLM_MODEL=gemma-4-31b-it
AGENT_TYPE=langgraph

# MCP Servers (launched automatically, no need to start them separately)
# Build spotify first: cd ../spotify-mcp-server && npm run build
# Build skills first:  cd ../jarvis-skills/rust-mcp-server && cargo build --release
MCP_SPOTIFY_TRANSPORT=stdio
SPOTIFY_MCP_COMMAND=node
SPOTIFY_MCP_ARGS=../spotify-mcp-server/build/index.js

MCP_SYSTEM_TRANSPORT=stdio
SYSTEM_MCP_COMMAND=../jarvis-skills/rust-mcp-server/target/release/jarvis-rust-mcp-server.exe
SYSTEM_MCP_ARGS=--stdio

# Fallback for old HTTP transport (if needed)
# MCP_SERVER_URL=http://127.0.0.1:5050

# Caching
LOG_LEVEL=INFO
LLM_RESPONSE_CACHE_ENABLED=true
LLM_RESPONSE_CACHE_TTL_SECONDS=180
LLM_RESPONSE_CACHE_MAX_ENTRIES=256
LLM_RESPONSE_CACHE_MIN_CHARS=24
# LLM_RESPONSE_CACHE_PATH=.cache/llm-response-cache.json
# LLM_RESPONSE_CACHE_ALLOW_TOOL_PROVIDERS=false

CONTEXT_CACHE_ENABLED=true
CONTEXT_DTYPE=fp16
CONTEXT_CACHE_MAX_TURNS=2

# Silence noisy library output
HF_HUB_LOG_LEVEL=error
SENTENCE_TRANSFORMERS_PROGRESS_BAR=0
HF_HUB_DISABLE_SYMLINKS_WARNING=1
PYTHONWARNINGS=ignore
HF_HUB_OFFLINE=1
HF_DATASETS_OFFLINE=1
