# JARVIS Chat Agent Configuration
# Copy this to .env and fill in your values

GEMINI_API_KEY=your-google-ai-studio-api-key-here
LLM_PROVIDER=gemini
LLM_MODEL=gemma-4-31b-it

# Agent implementation: 'legacy' (imperative) or 'langgraph' (declarative graph)
AGENT_TYPE=langgraph

# MCP endpoint used by jarvis-chat client
# Default target is the Rust MCP server in:
#   jarvis-skills/rust-mcp-server
MCP_SERVER_URL=http://127.0.0.1:5050

# --- Stdio MCP Server Configuration ---
# These settings are used by jarvis-chat's StdioMCPClient to launch the MCP servers.
# Ensure the commands (cargo, node) are in your PATH and the paths to binaries/scripts are correct.

# System MCP Server (Rust)
MCP_SYSTEM_TRANSPORT=stdio
RUST_MCP_COMMAND=cargo
RUST_MCP_ARGS=run --release -- --stdio

# Spotify MCP Server (Node.js)
MCP_SPOTIFY_TRANSPORT=stdio
SPOTIFY_MCP_COMMAND=node
SPOTIFY_MCP_ARGS=build/index.js 

# Logging
LOG_LEVEL=INFO

# Safe LLM response cache (Enabled by default in Phase 2)
LLM_RESPONSE_CACHE_ENABLED=true
LLM_RESPONSE_CACHE_TTL_SECONDS=180
LLM_RESPONSE_CACHE_MAX_ENTRIES=256
LLM_RESPONSE_CACHE_MIN_CHARS=24
# LLM_RESPONSE_CACHE_PATH=.cache/llm-response-cache.json
# LLM_RESPONSE_CACHE_ALLOW_TOOL_PROVIDERS=false
